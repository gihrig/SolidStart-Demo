{
  "name": "solidstart-demo",
  "type": "module",
  "scripts": {
    "audit": "bun audit",
    "build": "vinxi build",
    "check": "vp check --fix",
    "check:type": "vpx tsc --noEmit",
    "dev": "vinxi dev",
    "lighthouse": "concurrently -g 'vinxi build' 'vinxi start' 'CHROME_PATH=\"/Applications/Brave Browser.app/Contents/MacOS/Brave Browser\" lighthouse http://localhost:3000 --output html --output-path ./reports/lighthouse/lighthouse-report.html --view'",
    "start": "vinxi start",
    "test:all": "vp test",
    "test:all:watch": "vp test --watch",
    "test:comp": "vp test src/components",
    "test:comp:watch": "vp test src/components --watch",
    "test:cover": "vp test src --coverage --coverage.reportsDirectory=reports/coverage",
    "test:e2e": "./src/lib/test-e2e.sh",
    "test:show": "playwright show-report",
    "test:unit": "vp test src/lib",
    "test:unit:watch": "vp test --watch src/lib",
    "update": "bun update",
    "update:latest": "bun update --latest"
  },
  "devDependencies": {
    "@mdx-js/mdx": "3.1.1",
    "@playwright/test": "1.59.1",
    "@solidjs/meta": "0.29.4",
    "@solidjs/router": "0.16.1",
    "@solidjs/start": "1.3.2",
    "@solidjs/testing-library": "0.8.10",
    "@tailwindcss/postcss": "4.2.2",
    "@tailwindcss/vite": "4.2.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/user-event": "14.6.1",
    "@types/bun": "1.3.12",
    "@types/node": "25.6.0",
    "@vinxi/plugin-mdx": "3.7.2",
    "@vitest/coverage-v8": "4.1.4",
    "@vitest/ui": "4.1.4",
    "concurrently": "^9.2.1",
    "happy-dom": "20.9.0",
    "jsdom": "29.0.2",
    "postcss": "8.5.10",
    "solid-js": "1.9.12",
    "solid-mdx": "0.0.7",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.3",
    "vinxi": "0.5.11",
    "vite": "8.0.8",
    "vite-plugin-solid": "2.11.12",
    "vite-plus": "0.1.18"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.11",
  "trustedDependencies": [
    "@parcel/watcher"
  ]
}
